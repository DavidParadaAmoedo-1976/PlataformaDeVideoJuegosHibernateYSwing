<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>
        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/plataforma_de_videojuegos</property>
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password">abc123.</property>
        <property name="hibernate.hbm2ddl.auto">update</property>
        <property name="hibernate.dialect.storage_engine">innodb</property>
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>

        <mapping class="org.davidparada.modelo.entidad.UsuarioEntidad"/>
        <mapping class="org.davidparada.modelo.entidad.JuegoEntidad"/>
        <mapping class="org.davidparada.modelo.entidad.BibliotecaEntidad"/>
        <mapping class="org.davidparada.modelo.entidad.ResenaEntidad"/>
        <mapping class="org.davidparada.modelo.entidad.CompraEntidad"/>
    </session-factory>
</hibernate-configuration>